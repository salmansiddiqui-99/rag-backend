# Physical AI Textbook Backend - Environment Configuration
# ⚠️  SECURITY WARNING: NEVER commit actual API keys to the repository!
#
# Instructions:
# 1. Copy this file to .env in the same directory
# 2. Replace placeholder values with your actual credentials
# 3. .env is in .gitignore and will NOT be committed
# 4. For Railway deployment, set these in Railway Dashboard (NOT in code)

# ============================================================================
# 🔑 AI API KEYS (OPENROUTER IS REQUIRED)
# ============================================================================
# OpenRouter API - REQUIRED - Get from: https://openrouter.ai/
# OpenRouter provides access to Mistral, DeepSeek, and other models
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=mistralai/devstral-2512:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cohere API (for embeddings) - Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key-here

# ============================================================================
# 🗄️  VECTOR DATABASE (REQUIRED)
# ============================================================================
# Qdrant Cloud - Get from: https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=chapter_chunks
QDRANT_VECTOR_SIZE=1024

# ============================================================================
# 💾 DATABASE (REQUIRED)
# ============================================================================
# PostgreSQL connection string
# Neon example: postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# ============================================================================
# 🎯 RAG CONFIGURATION
# ============================================================================
RAG_SIMILARITY_THRESHOLD=0.5
RAG_TOP_K=5
RAG_TOP_K_CHUNKS=5
RAG_MAX_RESPONSE_TOKENS=1000
RAG_RESPONSE_TOKENS=800
RAG_CONTEXT_MAX_TOKENS=3000

# ============================================================================
# 🌐 CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
# Production example: https://username.github.io
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# 🔧 APPLICATION CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Physical AI Textbook API
API_VERSION=1.0.0
API_DESCRIPTION=Backend API for AI/Spec-Driven Book Creation
DEBUG=false

# ============================================================================
# 📝 LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# 🚀 FEATURE FLAGS
# ============================================================================
FEATURE_RAG_ENABLED=true
FEATURE_TEXT_SELECTION_MODE=true
FEATURE_PERFORMANCE_LOGGING=true
FEATURE_HALLUCINATION_DETECTION=true
FEATURE_STREAMING_RESPONSES=true

# ============================================================================
# 🤖 LLM PROVIDER SELECTION
# ============================================================================
# ONLY OpenRouter is supported. Do not change this value.
# Options: openrouter (required) | auto (will detect OpenRouter)
LLM_PROVIDER=openrouter

# ============================================================================
# ⚡ PERFORMANCE TUNING
# ============================================================================
EMBEDDING_CACHE_SIZE=1000
QDRANT_BATCH_SIZE=10
REQUEST_TIMEOUT_SECONDS=30
BATCH_SIZE=100

# ============================================================================
# 🗃️  DATABASE POOL CONFIGURATION
# ============================================================================
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============================================================================
# 🐙 GITHUB INTEGRATION (OPTIONAL)
# ============================================================================
GITHUB_REPO_OWNER=salmansiddiqui-99
GITHUB_REPO_NAME=hackathon1-Q4
