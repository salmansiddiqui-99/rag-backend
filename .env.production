# ========== Production Environment Configuration ==========
# For Railway Deployment
# This file documents production settings (NOT committed to repo with secrets)

# ========== Environment ==========
ENV=production
DEBUG=false

# ========== API Configuration ==========
API_TITLE=Physical AI Textbook API
API_VERSION=1.0.0
API_DESCRIPTION=FastAPI backend for Physical AI & Humanoid Robotics Textbook with RAG Chatbot

# ========== Server Configuration ==========
HOST=0.0.0.0
PORT=8000

# ========== CORS Configuration ==========
# MUST include GitHub Pages URL for frontend to connect
CORS_ORIGINS=https://salmansiddiqui-99.github.io,http://localhost:3000,http://localhost:3001

# ========== Database Configuration ==========
# Set DATABASE_URL in Railway Variables
# Format: postgresql://user:password@host:port/database?sslmode=require
# Example: postgresql://user:pass@db.neon.tech:5432/mydb?sslmode=require
DATABASE_URL=postgresql://localhost:5432/physical_ai

# ========== Qdrant Vector Store Configuration ==========
# Set in Railway Variables with your actual credentials
QDRANT_URL=https://your-qdrant-cloud-instance.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=chapter_chunks
QDRANT_VECTOR_SIZE=1024

# ========== LLM & AI API Keys ==========
# REQUIRED: Set in Railway Variables with your actual keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/devstral-2512:free
COHERE_API_KEY=your_cohere_api_key_here

# ========== RAG Configuration ==========
RAG_ENABLED=true
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.5

# ========== Logging Configuration ==========
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========== Security Configuration ==========
ALLOWED_HOSTS=hackathon1-q4-production.up.railway.app,salmansiddiqui-99.github.io

# ========== Optional Features ==========
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
